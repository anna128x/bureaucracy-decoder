# Copy to .env and fill in. Never commit your real .env.
ANTHROPIC_API_KEY=sk-ant-...

# Model is swappable. Default is claude-opus-4-8 (highest quality).
# For the cost-sensitive public demo, claude-sonnet-5 is ~5x cheaper and
# still strong at Russian — see RUNBOOK.md.
ANTHROPIC_MODEL=claude-opus-4-8

# Max characters of pasted letter text accepted per request (abuse/cost guard).
MAX_INPUT_CHARS=12000

# Simple per-IP rate limit for the public demo.
RATE_LIMIT_PER_MINUTE=6
